#!/usr/bin/env bash
# csm — Chrome Session Manager
# Save, load, list, and show parallel Chrome debug-mode sessions, each backed
# by its own user-data-dir and auto-allocated debug port.

set -euo pipefail

CONFIG_DIR="$HOME/.config/chrome-sessions"
STATE_DIR="$CONFIG_DIR/state"
PROFILES_DIR="$CONFIG_DIR/profiles"
BASE_PORT="${CSM_BASE_PORT:-${CSM_DEBUG_PORT:-9222}}"
read -r -a EXTRA_CHROME_ARGS <<< "${CSM_CHROME_ARGS:-}"
mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$PROFILES_DIR"

# ── Color setup ──────────────────────────────────────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_CYAN=$'\033[36m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_RESET=$'\033[0m'
else
    C_BOLD='' C_DIM='' C_CYAN='' C_GREEN='' C_YELLOW='' C_RESET=''
fi

_hr() {
    local n="$1" out='' i=0
    while [ "$i" -lt "$n" ]; do
        out+='─'
        i=$((i + 1))
    done
    printf '%s' "$out"
}

usage() {
    cat <<EOF
csm — Chrome Session Manager (parallel debug-mode sessions)

Usage:
  csm start <name>            Launch an empty debug Chrome under <name>.
  csm stop [name|all] [-q]    Stop a debug Chrome (default: only-running, current
                              if exactly one). "all" stops every running instance.
                              -q / --quiet skips the save + confirm prompts.
  csm status [name]           Show all running sessions; or details for <name>.
  csm save [name]             Save tabs from a running session.
                              No name → only-running; multiple running → picker.
  csm load <name>             Launch Chrome under <name> with saved tabs.
                              Prompts attach / reload / cancel if already running.
  csm list                    List saved configs with live status + tab titles.
  csm show <name>             Show every tab in a saved config.
  csm help                    Show this help.

Environment:
  CSM_BASE_PORT     Base port for debug-port allocation (default: 9222).
                    (Legacy alias: CSM_DEBUG_PORT.)
  CSM_CHROME_BIN    Chrome binary to use (default: auto-detect).
  CSM_CHROME_ARGS   Extra args appended to every chrome launch command.

Per-session state:
  Profiles    ~/.config/chrome-sessions/profiles/<name>/
  PID/port    ~/.config/chrome-sessions/state/<name>.json
  Configs     ~/.config/chrome-sessions/<name>.json
EOF
}

# ── Helpers: chrome bin ──────────────────────────────────────────────────────

_find_chrome() {
    if [ -n "${CSM_CHROME_BIN:-}" ]; then
        if command -v "$CSM_CHROME_BIN" >/dev/null 2>&1; then
            echo "$CSM_CHROME_BIN"
            return
        fi
    fi
    local bin
    for bin in google-chrome google-chrome-stable chromium chromium-browser chrome brave-browser; do
        if command -v "$bin" >/dev/null 2>&1; then
            echo "$bin"
            return
        fi
    done
    echo ""
}

_require_chrome_bin() {
    local bin
    bin=$(_find_chrome)
    if [ -z "$bin" ]; then
        echo "Error: No Chrome/Chromium binary found on PATH." >&2
        echo "       Set CSM_CHROME_BIN or install google-chrome / chromium." >&2
        exit 1
    fi
    echo "$bin"
}

# ── Helpers: port + state ────────────────────────────────────────────────────

_state_file()  { echo "$STATE_DIR/$1.json"; }
_profile_dir() { echo "$PROFILES_DIR/$1"; }

_port_free() {
    local port="$1"
    ! (exec 3<>/dev/tcp/127.0.0.1/"$port") 2>/dev/null
}

_alloc_port() {
    local port="$BASE_PORT"
    local max=$((BASE_PORT + 100))
    while [ "$port" -lt "$max" ]; do
        if _port_free "$port"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "Error: no free debug port in [$BASE_PORT, $max)" >&2
    return 1
}

_debug_alive_at() {
    local port="$1"
    curl -fsS --max-time 2 "http://localhost:$port/json/version" >/dev/null 2>&1
}

_session_port() {
    local f
    f=$(_state_file "$1")
    [ -f "$f" ] || return 1
    jq -r '.port' "$f"
}

_session_pid() {
    local f
    f=$(_state_file "$1")
    [ -f "$f" ] || return 1
    jq -r '.pid' "$f"
}

_session_alive() {
    local port
    port=$(_session_port "$1" 2>/dev/null) || return 1
    [ -n "$port" ] && _debug_alive_at "$port"
}

_clean_state_for() {
    rm -f "$(_state_file "$1")"
}

# Walk state dir; remove stale entries whose port no longer responds.
_clean_dead_state() {
    local f name
    [ -d "$STATE_DIR" ] || return 0
    for f in "$STATE_DIR"/*.json; do
        [ -f "$f" ] || continue
        name=$(basename "$f" .json)
        if ! _session_alive "$name"; then
            rm -f "$f"
        fi
    done
}

# Echo names of running sessions, one per line.
_running_sessions() {
    _clean_dead_state
    local f name
    [ -d "$STATE_DIR" ] || return 0
    for f in "$STATE_DIR"/*.json; do
        [ -f "$f" ] || continue
        name=$(basename "$f" .json)
        echo "$name"
    done
}

_wait_for_debug_port() {
    local port="$1"
    local waited=0
    while ! _debug_alive_at "$port" && [ "$waited" -lt 10 ]; do
        sleep 0.5
        waited=$((waited + 1))
    done
    _debug_alive_at "$port"
}

# Launch a new Chrome instance under <name> with the given URLs (which may be
# empty for an empty Chrome). Writes state on success.
# Args: $1 = name, rest = URLs.
_launch_session() {
    local name="$1"
    shift
    local urls=("$@")

    local chrome_bin
    chrome_bin=$(_require_chrome_bin)

    local profile_dir
    profile_dir=$(_profile_dir "$name")
    mkdir -p "$profile_dir"

    local port
    port=$(_alloc_port) || exit 1

    echo "Launching '$name' on port $port via $chrome_bin..."

    nohup "$chrome_bin" \
        --remote-debugging-port="$port" \
        --user-data-dir="$profile_dir" \
        ${EXTRA_CHROME_ARGS[@]+"${EXTRA_CHROME_ARGS[@]}"} \
        "${urls[@]}" \
        >/dev/null 2>&1 &
    local pid=$!
    disown

    if ! _wait_for_debug_port "$port"; then
        cat >&2 <<EOF
Warning: Launched chrome but debug port $port is not responding.

The flags may have been forwarded to an existing Chrome instance with the
same profile dir and ignored. Try 'csm stop $name' and retry, or close any
Chrome windows using the profile and try again.
EOF
        return 1
    fi

    jq -n \
        --arg name "$name" \
        --argjson pid "$pid" \
        --argjson port "$port" \
        --arg started_at "$(date -Iseconds)" \
        '{name: $name, pid: $pid, port: $port, started_at: $started_at}' \
        > "$(_state_file "$name")"

    echo "✓ '$name' alive. Endpoint: http://localhost:$port"
}

# ── Commands: start ──────────────────────────────────────────────────────────

cmd_start() {
    local name="${1:?Usage: csm start <name>}"

    if _session_alive "$name"; then
        local port
        port=$(_session_port "$name")
        echo "'$name' already running on port $port."
        echo "Endpoint: http://localhost:$port"
        return 0
    fi

    _clean_state_for "$name"
    _launch_session "$name"
}

# ── Commands: stop ───────────────────────────────────────────────────────────

# Kill a single named session and clean its state.
_stop_session() {
    local name="$1"
    local pid port
    pid=$(_session_pid "$name" 2>/dev/null || true)
    port=$(_session_port "$name" 2>/dev/null || true)

    if [ -z "$port" ] || ! _debug_alive_at "$port"; then
        _clean_state_for "$name"
        return 0
    fi

    echo "Stopping '$name' (pid $pid, port $port)..."
    if [ -n "$pid" ] && [ "$pid" != "null" ]; then
        kill "$pid" 2>/dev/null || true
    fi
    pkill -f "remote-debugging-port=$port" 2>/dev/null || true

    local waited=0
    while _debug_alive_at "$port" && [ "$waited" -lt 10 ]; do
        sleep 0.5
        waited=$((waited + 1))
    done

    _clean_state_for "$name"

    if _debug_alive_at "$port"; then
        echo "Warning: port $port still responding after kill." >&2
        return 1
    fi
    echo "Stopped '$name'."
}

cmd_stop() {
    local quiet=0
    local arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -q|--quiet) quiet=1 ;;
            -*) echo "Unknown flag: $1" >&2; exit 1 ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    local running=()
    local s
    while IFS= read -r s; do
        [ -n "$s" ] && running+=("$s")
    done < <(_running_sessions)

    if [ "${#running[@]}" -eq 0 ]; then
        echo "No running debug-chrome sessions."
        return 0
    fi

    local target=""
    if [ "$arg" = "all" ] || [ "$arg" = "--all" ]; then
        if [ "$quiet" -eq 0 ]; then
            local saveq
            read -rp "Save any sessions before stopping? [y/N] " saveq
            if [[ "$saveq" =~ ^[Yy]$ ]]; then
                for s in "${running[@]}"; do
                    local sn
                    read -rp "Save '$s' as (blank to skip): " sn
                    if [ -n "$sn" ]; then
                        _save_session "$sn" "$s"
                    fi
                done
            fi
        fi
        for s in "${running[@]}"; do
            _stop_session "$s"
        done
        return
    fi

    if [ -n "$arg" ]; then
        target="$arg"
    elif [ "${#running[@]}" -eq 1 ]; then
        target="${running[0]}"
    else
        echo "Running sessions:"
        local i=1
        for s in "${running[@]}"; do
            echo "  $i) $s"
            i=$((i + 1))
        done
        local pick
        read -rp "Pick session to stop [1-${#running[@]}]: " pick
        if ! [[ "$pick" =~ ^[0-9]+$ ]] || [ "$pick" -lt 1 ] || [ "$pick" -gt "${#running[@]}" ]; then
            echo "Aborted."
            exit 0
        fi
        target="${running[$((pick - 1))]}"
    fi

    if ! _session_alive "$target"; then
        echo "No running session '$target'."
        _clean_state_for "$target"
        return 0
    fi

    if [ "$quiet" -eq 0 ]; then
        local saveq
        read -rp "Save '$target' tabs before stop? [Y/n] " saveq
        if [[ ! "$saveq" =~ ^[Nn]$ ]]; then
            local sn
            read -rp "Save name [$target]: " sn
            sn="${sn:-$target}"
            _save_session "$sn" "$target"
        fi
    fi

    _stop_session "$target"
}

# ── Commands: status ─────────────────────────────────────────────────────────

cmd_status() {
    local name="${1:-}"

    if [ -n "$name" ]; then
        if ! _session_alive "$name"; then
            printf "${C_YELLOW}○${C_RESET} '%s' is not running.\n" "$name"
            exit 1
        fi
        local port pid browser tab_count
        port=$(_session_port "$name")
        pid=$(_session_pid "$name")
        browser=$(curl -fsS "http://localhost:$port/json/version" | jq -r '.Browser // "unknown"')
        tab_count=$(curl -fsS "http://localhost:$port/json" | jq '[.[] | select(.type == "page")] | length')
        printf "${C_GREEN}●${C_RESET} %s alive (pid ${C_CYAN}%s${C_RESET}, port ${C_CYAN}%s${C_RESET})\n" "$name" "$pid" "$port"
        printf "  browser:  ${C_DIM}%s${C_RESET}\n" "$browser"
        printf "  tabs:     ${C_DIM}%s${C_RESET}\n" "$tab_count"
        printf "  endpoint: ${C_DIM}http://localhost:%s${C_RESET}\n" "$port"
        return
    fi

    local running=()
    local s
    while IFS= read -r s; do
        [ -n "$s" ] && running+=("$s")
    done < <(_running_sessions)

    if [ "${#running[@]}" -eq 0 ]; then
        printf "${C_YELLOW}○${C_RESET} No debug chrome sessions running.\n"
        exit 1
    fi

    printf "${C_BOLD}Running debug-chrome sessions:${C_RESET}\n\n"
    printf "  ${C_CYAN}${C_BOLD}%-12s  %-6s  %-7s  %s${C_RESET}\n" "NAME" "PORT" "PID" "TABS"
    printf "  ${C_DIM}%s  %s  %s  %s${C_RESET}\n" "$(_hr 12)" "$(_hr 6)" "$(_hr 7)" "$(_hr 4)"
    for s in "${running[@]}"; do
        local port pid tab_count
        port=$(_session_port "$s")
        pid=$(_session_pid "$s")
        tab_count=$(curl -fsS --max-time 2 "http://localhost:$port/json" 2>/dev/null \
            | jq '[.[] | select(.type == "page")] | length' 2>/dev/null || echo "?")
        printf "  ${C_BOLD}%-12s${C_RESET}  ${C_CYAN}%-6s${C_RESET}  ${C_DIM}%-7s${C_RESET}  ${C_GREEN}%s${C_RESET}\n" \
            "$s" "$port" "$pid" "$tab_count"
    done
}

# ── Commands: save ───────────────────────────────────────────────────────────

# Snapshot a running session's tabs into config <save_name>.
# Args: $1 = save_name, $2 = source_session_name
_save_session() {
    local save_name="$1"
    local source="$2"

    local port
    port=$(_session_port "$source") || {
        echo "Error: no running session '$source'." >&2
        return 1
    }
    if ! _debug_alive_at "$port"; then
        echo "Error: session '$source' not responding on port $port." >&2
        return 1
    fi

    local config_file="$CONFIG_DIR/${save_name}.json"
    local tabs_json browser
    tabs_json=$(curl -fsS "http://localhost:$port/json" \
        | jq '[.[] | select(.type == "page")]
              | to_entries
              | map({index: .key, title: .value.title, url: .value.url})')
    browser=$(curl -fsS "http://localhost:$port/json/version" | jq -r '.Browser // "unknown"')

    jq -n \
        --arg name "$save_name" \
        --arg saved_at "$(date -Iseconds)" \
        --arg browser "$browser" \
        --argjson port "$port" \
        --argjson tabs "$tabs_json" \
        '{name: $name, saved_at: $saved_at, browser: $browser, debug_port: $port, tabs: $tabs}' \
        > "$config_file"

    echo "Saved session '$source' as '$save_name' → $config_file"
}

cmd_save() {
    local name="${1:-}"
    local running=()
    local s
    while IFS= read -r s; do
        [ -n "$s" ] && running+=("$s")
    done < <(_running_sessions)

    if [ "${#running[@]}" -eq 0 ]; then
        echo "Error: no debug-chrome sessions running. Start one with 'csm start <name>'." >&2
        exit 1
    fi

    local source=""
    if [ -n "$name" ]; then
        for s in "${running[@]}"; do
            if [ "$s" = "$name" ]; then
                source="$s"
                break
            fi
        done
        if [ -z "$source" ]; then
            if [ "${#running[@]}" -eq 1 ]; then
                source="${running[0]}"
            else
                echo "Multiple sessions running, none named '$name':"
                local i=1
                for s in "${running[@]}"; do
                    echo "  $i) $s"
                    i=$((i + 1))
                done
                local pick
                read -rp "Pick session to save as '$name' [1-${#running[@]}]: " pick
                if ! [[ "$pick" =~ ^[0-9]+$ ]] || [ "$pick" -lt 1 ] || [ "$pick" -gt "${#running[@]}" ]; then
                    echo "Aborted."
                    exit 0
                fi
                source="${running[$((pick - 1))]}"
            fi
        fi
    else
        if [ "${#running[@]}" -gt 1 ]; then
            echo "Multiple sessions running. Pass a name or pick:" >&2
            local i=1
            for s in "${running[@]}"; do
                echo "  $i) $s" >&2
                i=$((i + 1))
            done
            local pick
            read -rp "Pick session to save (under same name) [1-${#running[@]}]: " pick
            if ! [[ "$pick" =~ ^[0-9]+$ ]] || [ "$pick" -lt 1 ] || [ "$pick" -gt "${#running[@]}" ]; then
                echo "Aborted."
                exit 0
            fi
            source="${running[$((pick - 1))]}"
        else
            source="${running[0]}"
        fi
        name="$source"
    fi

    _save_session "$name" "$source"
    echo ""
    cmd_show "$name"
}

# ── Commands: load ───────────────────────────────────────────────────────────

cmd_load() {
    local name="${1:?Usage: csm load <name>}"
    local config_file="$CONFIG_DIR/${name}.json"

    if [ ! -f "$config_file" ]; then
        echo "Error: No saved config '$name'. Run 'csm list' to see available configs." >&2
        exit 1
    fi

    local tab_count
    tab_count=$(jq '.tabs | length' "$config_file")

    if [ "$tab_count" -eq 0 ]; then
        echo "Error: Config '$name' has no tabs." >&2
        exit 1
    fi

    if _session_alive "$name"; then
        local port
        port=$(_session_port "$name")
        echo "Session '$name' is already running on port $port."
        echo "  [a] leave it (no-op)"
        echo "  [r] reload (kill and recreate from saved config)"
        echo "  [c] cancel"
        local ans
        read -rp "Choice [a/r/c]: " ans
        case "$ans" in
            a|A)
                echo "Leaving '$name' running. Endpoint: http://localhost:$port"
                return 0
                ;;
            r|R)
                _stop_session "$name"
                ;;
            *)
                echo "Aborted."
                exit 0
                ;;
        esac
    fi
    _clean_state_for "$name"

    local urls=()
    local url
    while IFS= read -r url; do
        [ -n "$url" ] && urls+=("$url")
    done < <(jq -r '.tabs[].url' "$config_file")

    _launch_session "$name" "${urls[@]}"
}

# ── Commands: list ───────────────────────────────────────────────────────────

_render_status_cell() {
    local status="$1" width="$2" out='' visible=0
    case "$status" in
        live)
            out="${C_GREEN}● live${C_RESET}"
            visible=6
            ;;
    esac
    local pad=$((width - visible))
    (( pad > 0 )) && out+="$(printf '%*s' "$pad" '')"
    printf '%s' "$out"
}

cmd_list() {
    local found=0
    local f
    for f in "$CONFIG_DIR"/*.json; do
        [ -f "$f" ] && found=1 && break
    done
    if [ "$found" -eq 0 ]; then
        echo "No saved sessions. Use 'csm save <name>' to save one."
        return
    fi

    declare -A live_names
    local s
    while IFS= read -r s; do
        [ -n "$s" ] && live_names["$s"]=1
    done < <(_running_sessions)

    local term_cols
    term_cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 120)}

    local rows=()
    local w_name=4 w_date=8 w_status=6
    local sname saved_at tabs_full status
    for f in "$CONFIG_DIR"/*.json; do
        [ -f "$f" ] || continue
        sname=$(jq -r '.name // empty' "$f" 2>/dev/null)
        [ -z "$sname" ] && continue
        saved_at=$(jq -r '.saved_at | sub("T"; " ") | sub("[+-][0-9]{2}:[0-9]{2}$"; "")' "$f")
        tabs_full=$(jq -r '[.tabs[].title] | join(", ")' "$f")
        status=""
        [ -n "${live_names[$sname]+x}" ] && status="live"

        rows+=("${sname}"$'\x1f'"${saved_at}"$'\x1f'"${status}"$'\x1f'"${tabs_full}")
        (( ${#sname}    > w_name )) && w_name=${#sname}
        (( ${#saved_at} > w_date )) && w_date=${#saved_at}
    done

    # Layout: 2sp + name + 2sp + date + 2sp + status + 2sp + tabs
    local fixed=$((2 + w_name + 2 + w_date + 2 + w_status + 2))
    local w_tabs=$((term_cols - fixed))
    (( w_tabs < 20 )) && w_tabs=20

    printf "${C_BOLD}Saved chrome sessions:${C_RESET}\n\n"
    printf "  ${C_CYAN}${C_BOLD}%-*s  %-*s  %-*s  %s${C_RESET}\n" \
        "$w_name" "NAME" "$w_date" "SAVED AT" "$w_status" "STATUS" "TABS"
    printf "  ${C_DIM}%s  %s  %s  %s${C_RESET}\n" \
        "$(_hr "$w_name")" "$(_hr "$w_date")" "$(_hr "$w_status")" "$(_hr 4)"

    local row
    for row in "${rows[@]}"; do
        IFS=$'\x1f' read -r sname saved_at status tabs_full <<< "$row"
        local status_cell
        status_cell=$(_render_status_cell "$status" "$w_status")
        local tabs_cell="$tabs_full"
        if [ "${#tabs_cell}" -gt "$w_tabs" ]; then
            tabs_cell="${tabs_cell:0:$((w_tabs - 1))}…"
        fi
        printf "  ${C_BOLD}%-*s${C_RESET}  ${C_DIM}%-*s${C_RESET}  %s  ${C_GREEN}%s${C_RESET}\n" \
            "$w_name" "$sname" "$w_date" "$saved_at" "$status_cell" "$tabs_cell"
    done
}

# ── Commands: show ───────────────────────────────────────────────────────────

cmd_show() {
    local name="${1:?Usage: csm show <name>}"
    local config_file="$CONFIG_DIR/${name}.json"

    if [ ! -f "$config_file" ]; then
        echo "Error: No saved config '$name'." >&2
        exit 1
    fi

    local tab_count browser
    tab_count=$(jq '.tabs | length' "$config_file")
    browser=$(jq -r '.browser // "unknown"' "$config_file")

    local rows=()
    local w_idx=1 w_title=5
    local idx title url
    while IFS=$'\t' read -r idx title url; do
        if [ "${#title}" -gt 60 ]; then
            title="${title:0:57}..."
        fi
        rows+=("${idx}"$'\t'"${title}"$'\t'"${url}")
        (( ${#idx}   > w_idx   )) && w_idx=${#idx}
        (( ${#title} > w_title )) && w_title=${#title}
    done < <(jq -r '.tabs[] | [.index, .title, .url] | @tsv' "$config_file")

    printf "${C_BOLD}Session:${C_RESET} ${C_CYAN}%s${C_RESET} ${C_DIM}(%s tabs — %s)${C_RESET}\n\n" \
        "$name" "$tab_count" "$browser"
    printf "  ${C_CYAN}${C_BOLD}%-*s  %-*s  %s${C_RESET}\n" \
        "$w_idx" "#" "$w_title" "TITLE" "URL"
    printf "  ${C_DIM}%s  %s  %s${C_RESET}\n" \
        "$(_hr "$w_idx")" "$(_hr "$w_title")" "$(_hr 3)"

    local row
    for row in "${rows[@]}"; do
        IFS=$'\t' read -r idx title url <<< "$row"
        printf "  ${C_YELLOW}%-*s${C_RESET}  ${C_BOLD}%-*s${C_RESET}  ${C_GREEN}%s${C_RESET}\n" \
            "$w_idx" "$idx" "$w_title" "$title" "$url"
    done
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    start)  shift; cmd_start  "$@" ;;
    stop)   shift; cmd_stop   "$@" ;;
    status) shift; cmd_status "$@" ;;
    save)   shift; cmd_save   "$@" ;;
    load)   shift; cmd_load   "$@" ;;
    list)   shift; cmd_list   "$@" ;;
    show)   shift; cmd_show   "$@" ;;
    help|-h|--help) usage ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
