#!/usr/bin/env bash
# bsm — Byobu Session Manager
# Save, load, list, and shutdown byobu sessions with named configs.

set -euo pipefail

CONFIG_DIR="$HOME/.config/byobu-sessions"
mkdir -p "$CONFIG_DIR"

# ── Color setup ──────────────────────────────────────────────────────────────
# Respect NO_COLOR and disable when stdout isn't a terminal.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_CYAN=$'\033[36m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_RESET=$'\033[0m'
else
    C_BOLD='' C_DIM='' C_CYAN='' C_GREEN='' C_YELLOW='' C_RESET=''
fi

# Print N box-drawing horizontal line characters
_hr() {
    local n="$1" out='' i=0
    while [ "$i" -lt "$n" ]; do
        out+='─'
        i=$((i + 1))
    done
    printf '%s' "$out"
}

usage() {
    cat <<'EOF'
bsm — Byobu Session Manager

Usage:
  bsm save [name]         Save current byobu session as <name>
                          (no arg: defaults to current session name when inside tmux)
  bsm load <name>         Load a saved session config as a tmux session named <name>.
                          Runs alongside other live sessions; prompts on collision.
  bsm list                List saved configs with live/drift status
  bsm show <name>         Show contents of a saved config
  bsm delete <name>       Delete a saved session config (use -f to skip confirmation)
  bsm shutdown [name|all] Shut down a session (default: current when inside tmux,
                          else picker). Use "all" to kill the entire byobu server.
  bsm help                Show this help

Configs are stored as JSON in ~/.config/byobu-sessions/
EOF
}

# ── Helpers ──────────────────────────────────────────────────────────────────

_require_byobu() {
    if ! byobu list-sessions &>/dev/null; then
        echo "Error: No active byobu session found." >&2
        exit 1
    fi
}

_get_full_command() {
    local pane_pid="$1"
    local child_pids
    child_pids=$(pgrep -P "$pane_pid" 2>/dev/null || true)

    if [ -z "$child_pids" ]; then
        echo ""
        return
    fi

    # Get the command line of the first child (the main running process)
    local first_child
    first_child=$(echo "$child_pids" | head -1)

    # Use /proc to get full cmdline, falling back to ps
    if [ -f "/proc/$first_child/cmdline" ]; then
        # cmdline uses null bytes as separators
        tr '\0' ' ' < "/proc/$first_child/cmdline" | sed 's/ $//'
    else
        ps -p "$first_child" -o args= 2>/dev/null | sed 's/^ *//'
    fi
}

# ── Save ─────────────────────────────────────────────────────────────────────

# Pick a target tmux session for save/shutdown actions.
# Echoes the chosen session name on stdout, returns 1 on cancel.
# Args: $1 = action label (e.g. "save", "shutdown") used only in prompts.
_pick_session() {
    local action="$1"
    local sessions=()
    local s
    while IFS= read -r s; do
        [ -z "$s" ] && continue
        sessions+=("$s")
    done < <(byobu list-sessions -F '#{session_name}' 2>/dev/null || true)

    if [ "${#sessions[@]}" -eq 0 ]; then
        echo "Error: No live byobu sessions." >&2
        return 1
    fi

    if [ -n "${TMUX:-}" ]; then
        tmux display-message -p '#S'
        return 0
    fi

    if [ "${#sessions[@]}" -eq 1 ]; then
        echo "${sessions[0]}"
        return 0
    fi

    echo "Multiple live sessions:" >&2
    local i=1
    for s in "${sessions[@]}"; do
        echo "  $i) $s" >&2
        i=$((i + 1))
    done
    local pick
    read -rp "Pick session to ${action} [1-${#sessions[@]}]: " pick
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || [ "$pick" -lt 1 ] || [ "$pick" -gt "${#sessions[@]}" ]; then
        echo "Aborted." >&2
        return 1
    fi
    echo "${sessions[$((pick - 1))]}"
}

# Snapshot a live tmux session to a JSON config.
# Args: $1 = config name, $2 = live tmux session name.
_save_session() {
    local name="$1"
    local target_session="$2"
    local config_file="$CONFIG_DIR/${name}.json"
    local windows_json="[]"

    while IFS='|' read -r idx wname wpath _ pane_pid; do
        local cmd
        cmd=$(_get_full_command "$pane_pid")
        windows_json=$(echo "$windows_json" | jq \
            --argjson idx "$idx" \
            --arg name "$wname" \
            --arg dir "$wpath" \
            --arg cmd "$cmd" \
            '. + [{index: $idx, name: $name, directory: $dir, command: $cmd}]')
    done < <(byobu list-panes -t "$target_session" -s -F '#{window_index}|#{window_name}|#{pane_current_path}|#{pane_current_command}|#{pane_pid}')

    jq -n \
        --arg name "$name" \
        --arg saved_at "$(date -Iseconds)" \
        --arg session "$target_session" \
        --argjson windows "$windows_json" \
        '{name: $name, saved_at: $saved_at, session_name: $session, windows: $windows}' \
        > "$config_file"

    echo "Saved session '$target_session' as '$name' → $config_file"
}

cmd_save() {
    local name="${1:-}"
    _require_byobu

    local target_session
    if [ -z "$name" ]; then
        # No name → must be inside tmux; default name = current session name.
        if [ -z "${TMUX:-}" ]; then
            echo "Error: No name given and not inside a byobu session." >&2
            echo "Usage: bsm save <name>" >&2
            exit 1
        fi
        target_session=$(tmux display-message -p '#S')
        name="$target_session"
    else
        target_session=$(_pick_session "save as '$name'") || exit 0
    fi

    _save_session "$name" "$target_session"
    echo ""
    cmd_show "$name"
}

# ── Load ─────────────────────────────────────────────────────────────────────

_attach_or_switch() {
    local session="$1"
    if [ -n "${TMUX:-}" ]; then
        echo "Switching client to '$session'..."
        tmux switch-client -t "$session"
    else
        echo "Attaching to '$session'..."
        byobu attach -t "$session"
    fi
}

cmd_load() {
    local name="${1:?Usage: bsm load <name>}"
    local config_file="$CONFIG_DIR/${name}.json"

    if [ ! -f "$config_file" ]; then
        echo "Error: No saved config '$name'. Run 'bsm list' to see available configs." >&2
        exit 1
    fi

    # Config name == tmux session name. Lets us check "is this loaded?" by
    # session lookup instead of fingerprinting.
    local session="$name"

    if tmux has-session -t "$session" 2>/dev/null; then
        echo "Session '$session' is already running."
        echo "  [a] attach (or switch) to it as-is"
        echo "  [r] reload (kill and recreate from saved config)"
        echo "  [c] cancel"
        local ans
        read -rp "Choice [a/r/c]: " ans
        case "$ans" in
            a|A)
                _attach_or_switch "$session"
                return
                ;;
            r|R)
                tmux kill-session -t "$session" 2>/dev/null || true
                ;;
            *)
                echo "Aborted."
                exit 0
                ;;
        esac
    fi

    local win_count
    win_count=$(jq '.windows | length' "$config_file")

    if [ "$win_count" -eq 0 ]; then
        echo "Error: Config '$name' has no windows." >&2
        exit 1
    fi

    echo "Loading session '$session' ($win_count windows)..."

    # Create session with the first window
    local first_name first_dir first_cmd
    first_name=$(jq -r '.windows[0].name' "$config_file")
    first_dir=$(jq -r '.windows[0].directory' "$config_file")
    first_cmd=$(jq -r '.windows[0].command // ""' "$config_file")

    byobu new-session -d -s "$session" -n "$first_name" -c "$first_dir"

    # Kill any extra windows that byobu may have auto-created during session startup
    local extra_windows
    extra_windows=$(byobu list-windows -t "$session" -F '#{window_index}' | tail -n +2 || true)
    for win_idx in $extra_windows; do
        byobu kill-window -t "${session}:${win_idx}" 2>/dev/null || true
    done

    if [ -n "$first_cmd" ]; then
        byobu send-keys -t "${session}:${first_name}" "$first_cmd" Enter
    fi

    # Create remaining windows
    for i in $(seq 1 $((win_count - 1))); do
        local wname wdir wcmd widx
        wname=$(jq -r ".windows[$i].name" "$config_file")
        wdir=$(jq -r ".windows[$i].directory" "$config_file")
        wcmd=$(jq -r ".windows[$i].command // \"\"" "$config_file")
        widx=$(jq -r ".windows[$i].index" "$config_file")

        byobu new-window -t "${session}:${widx}" -n "$wname" -c "$wdir"

        if [ -n "$wcmd" ]; then
            byobu send-keys -t "${session}:${wname}" "$wcmd" Enter
        fi
    done

    # Select the first window
    byobu select-window -t "${session}:0"

    _attach_or_switch "$session"
}

# ── List ─────────────────────────────────────────────────────────────────────

_render_status_cell() {
    local status="$1" width="$2" out='' visible=0
    case "$status" in
        live)
            out="${C_GREEN}● live${C_RESET}"
            visible=6
            ;;
        drift)
            out="${C_YELLOW}~ drift${C_RESET}"
            visible=7
            ;;
    esac
    local pad=$((width - visible))
    (( pad > 0 )) && out+="$(printf '%*s' "$pad" '')"
    printf '%s' "$out"
}

cmd_list() {
    local configs
    configs=$(find "$CONFIG_DIR" -name '*.json' -type f 2>/dev/null)

    if [ -z "$configs" ]; then
        echo "No saved sessions. Use 'bsm save <name>' to save one."
        return
    fi

    # Map of live tmux sessions → window-name fingerprint. Lets us flag
    # configs as `live` (session exists, windows match) or `drift` (session
    # exists, windows changed since save).
    declare -A live_fp
    if byobu list-sessions &>/dev/null; then
        local live_s
        while IFS= read -r live_s; do
            [ -z "$live_s" ] && continue
            live_fp["$live_s"]=$(byobu list-windows -t "$live_s" -F '#{window_name}' 2>/dev/null | paste -sd ',' -)
        done < <(byobu list-sessions -F '#{session_name}' 2>/dev/null)
    fi

    # Collect rows and compute column widths dynamically so data never overflows.
    local rows=()
    local w_name=4 w_date=8 w_status=7
    local f sname saved_at win_summary status saved_fp
    for f in "$CONFIG_DIR"/*.json; do
        [ -f "$f" ] || continue
        sname=$(jq -r '.name' "$f")
        saved_at=$(jq -r '.saved_at | sub("T"; " ") | sub("[+-][0-9]{2}:[0-9]{2}$"; "")' "$f")
        win_summary=$(jq -r '[.windows[].name] | join(", ")' "$f")
        saved_fp=$(jq -r '[.windows[].name] | join(",")' "$f")
        status=""
        if [ -n "${live_fp[$sname]+x}" ]; then
            if [ "${live_fp[$sname]}" = "$saved_fp" ]; then
                status="live"
            else
                status="drift"
            fi
        fi
        rows+=("${sname}"$'\x1f'"${saved_at}"$'\x1f'"${status}"$'\x1f'"${win_summary}")
        (( ${#sname}    > w_name )) && w_name=${#sname}
        (( ${#saved_at} > w_date )) && w_date=${#saved_at}
    done

    printf "${C_BOLD}Saved byobu sessions:${C_RESET}\n\n"
    printf "  ${C_CYAN}${C_BOLD}%-*s  %-*s  %-*s  %s${C_RESET}\n" \
        "$w_name" "NAME" "$w_date" "SAVED AT" "$w_status" "STATUS" "WINDOWS"
    printf "  ${C_DIM}%s  %s  %s  %s${C_RESET}\n" \
        "$(_hr "$w_name")" "$(_hr "$w_date")" "$(_hr "$w_status")" "$(_hr 7)"

    local row
    for row in "${rows[@]}"; do
        IFS=$'\x1f' read -r sname saved_at status win_summary <<< "$row"
        local status_cell
        status_cell=$(_render_status_cell "$status" "$w_status")
        printf "  ${C_BOLD}%-*s${C_RESET}  ${C_DIM}%-*s${C_RESET}  %s  ${C_GREEN}%s${C_RESET}\n" \
            "$w_name" "$sname" "$w_date" "$saved_at" "$status_cell" "$win_summary"
    done
}

# ── Show ─────────────────────────────────────────────────────────────────────

cmd_show() {
    local name="${1:?Usage: bsm show <name>}"
    local config_file="$CONFIG_DIR/${name}.json"

    if [ ! -f "$config_file" ]; then
        echo "Error: No saved config '$name'." >&2
        exit 1
    fi

    local win_count
    win_count=$(jq '.windows | length' "$config_file")

    # Collect rows and compute column widths dynamically.
    local rows=()
    local w_idx=1 w_name=4 w_dir=9
    local idx wname wdir wcmd
    while IFS='|' read -r idx wname wdir wcmd; do
        wdir="${wdir/#$HOME/~}"
        [ -z "$wcmd" ] && wcmd="(idle)"
        rows+=("${idx}"$'\t'"${wname}"$'\t'"${wdir}"$'\t'"${wcmd}")
        (( ${#idx}   > w_idx  )) && w_idx=${#idx}
        (( ${#wname} > w_name )) && w_name=${#wname}
        (( ${#wdir}  > w_dir  )) && w_dir=${#wdir}
    done < <(jq -r '.windows[] | "\(.index)|\(.name)|\(.directory)|\(.command // "")"' "$config_file")

    printf "${C_BOLD}Session:${C_RESET} ${C_CYAN}%s${C_RESET} ${C_DIM}(%s windows)${C_RESET}\n\n" \
        "$name" "$win_count"
    printf "  ${C_CYAN}${C_BOLD}%-*s  %-*s  %-*s  %s${C_RESET}\n" \
        "$w_idx" "#" "$w_name" "NAME" "$w_dir" "DIRECTORY" "COMMAND"
    printf "  ${C_DIM}%s  %s  %s  %s${C_RESET}\n" \
        "$(_hr "$w_idx")" "$(_hr "$w_name")" "$(_hr "$w_dir")" "$(_hr 7)"

    local row
    for row in "${rows[@]}"; do
        IFS=$'\t' read -r idx wname wdir wcmd <<< "$row"
        printf "  ${C_YELLOW}%-*s${C_RESET}  ${C_BOLD}%-*s${C_RESET}  ${C_DIM}%-*s${C_RESET}  ${C_GREEN}%s${C_RESET}\n" \
            "$w_idx" "$idx" "$w_name" "$wname" "$w_dir" "$wdir" "$wcmd"
    done
}

# ── Delete ───────────────────────────────────────────────────────────────────

cmd_delete() {
    local force=0
    local name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force) force=1 ;;
            -*) echo "Unknown flag: $1" >&2; exit 1 ;;
            *) name="$1" ;;
        esac
        shift
    done

    [ -n "$name" ] || { echo "Usage: bsm delete <name> [-f]" >&2; exit 1; }

    local config_file="$CONFIG_DIR/${name}.json"
    if [ ! -f "$config_file" ]; then
        echo "Error: No saved config '$name'. Run 'bsm list' to see available configs." >&2
        exit 1
    fi

    if [ "$force" -ne 1 ]; then
        read -rp "Delete saved session '$name'? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 0
        fi
    fi

    rm -f "$config_file"
    echo "Deleted '$name' → $config_file"
}

# ── Shutdown ─────────────────────────────────────────────────────────────────

cmd_shutdown() {
    _require_byobu

    local arg="${1:-}"
    local sessions=()
    local s
    while IFS= read -r s; do
        [ -z "$s" ] && continue
        sessions+=("$s")
    done < <(byobu list-sessions -F '#{session_name}' 2>/dev/null)

    local target=""
    if [ "$arg" = "all" ] || [ "$arg" = "--all" ]; then
        target="__all__"
    elif [ -n "$arg" ]; then
        target="$arg"
    elif [ -n "${TMUX:-}" ]; then
        target=$(tmux display-message -p '#S')
    elif [ "${#sessions[@]}" -eq 1 ]; then
        target="${sessions[0]}"
    else
        echo "Active sessions:"
        local i=1
        for s in "${sessions[@]}"; do
            echo "  $i) $s"
            i=$((i + 1))
        done
        echo "  $i) all (kill server)"
        local pick
        read -rp "Pick session to shutdown [1-$i]: " pick
        if ! [[ "$pick" =~ ^[0-9]+$ ]] || [ "$pick" -lt 1 ] || [ "$pick" -gt "$i" ]; then
            echo "Aborted."
            exit 0
        fi
        if [ "$pick" -eq "$i" ]; then
            target="__all__"
        else
            target="${sessions[$((pick - 1))]}"
        fi
    fi

    if [ "$target" = "__all__" ]; then
        local save_answer
        read -rp "Save any sessions before shutdown? [y/N] " save_answer
        if [[ "$save_answer" =~ ^[Yy]$ ]]; then
            for s in "${sessions[@]}"; do
                local save_name
                read -rp "Save '$s' as (blank to skip): " save_name
                if [ -n "$save_name" ]; then
                    _save_session "$save_name" "$s"
                fi
            done
        fi
        local ans
        read -rp "Kill ALL byobu sessions? This terminates every running process. [y/N] " ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
            byobu kill-server
            echo "All sessions terminated."
        else
            echo "Aborted."
        fi
        return
    fi

    if ! tmux has-session -t "$target" 2>/dev/null; then
        echo "Error: No live session '$target'." >&2
        exit 1
    fi

    local save_answer
    read -rp "Save '$target' before shutdown? [Y/n] " save_answer
    if [[ ! "$save_answer" =~ ^[Nn]$ ]]; then
        local save_name
        read -rp "Save name [$target]: " save_name
        save_name="${save_name:-$target}"
        _save_session "$save_name" "$target"
    fi

    local ans
    read -rp "Kill session '$target'? [y/N] " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
        tmux kill-session -t "$target"
        echo "Session '$target' terminated."
    else
        echo "Aborted."
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    save)     shift; cmd_save "$@" ;;
    load)     shift; cmd_load "$@" ;;
    list)     shift; cmd_list "$@" ;;
    show)     shift; cmd_show "$@" ;;
    delete|rm) shift; cmd_delete "$@" ;;
    shutdown) shift; cmd_shutdown "$@" ;;
    help|-h|--help) usage ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
